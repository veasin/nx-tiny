{
  "name":"veasin/nx-tiny",
  "description":"A minimalist, functional PHP framework. Focus on declarative config, tail-call optimization, and clear domain modeling.",
  "type":"library",
  "license":"LGPL-3.0-or-later",
  "authors":[
    {
      "name":"V",
      "email":"vea.git@gmail.com"
    }
  ],
  "require":{
    "php":"^8.4",
    "ext-pdo":"*",
    "ext-json":"*"
  },
  "require-dev":{
    "veasin/nx-sql":"*"
  },
  "autoload":{
    "psr-4":{
      "nx\\":"src/"
    },
    "files":[
      "src/test.php",
      "src/container.php",
      "src/filter.php",
      "src/args.php",
      "src/input.php",
      "src/output.php",
      "src/name.php",
      "src/run.php",
      "src/middleware.php",
      "src/route.php",
      "src/db.php",
      "src/cache.php"
    ]
  }
}
